/* Genera un'immagine grande e brandizzata (titolo + QR + codice) e la
   condivide con la scheda di condivisione del telefono (WhatsApp incluso).
   Se la condivisione file non è supportata, la scarica come PNG. */
async function shareQrImage(shareCode, joinLink){
  const statusEl = document.getElementById('shareStatus');
  const setStatus = t => { if(statusEl) statusEl.textContent = t; };
  setStatus('Preparo l\'immagine…');

  // 1) Genera un QR grande in un contenitore nascosto
  const hidden = document.createElement('div');
  hidden.style.position = 'fixed'; hidden.style.left = '-9999px';
  document.body.appendChild(hidden);
  try{ new QRCode(hidden, { text: joinLink, width: 600, height: 600 }); }
  catch(e){ document.body.removeChild(hidden); setStatus('Impossibile generare il QR.'); return; }
  // La libreria disegna in un canvas (o img) dentro il contenitore
  await new Promise(r => setTimeout(r, 120));
  const qrCanvas = hidden.querySelector('canvas');
  const qrImg = hidden.querySelector('img');

  // 2) Componi il poster su un canvas grande
  const W = 1080, H = 1500;
  const c = document.createElement('canvas');
  c.width = W; c.height = H;
  const ctx = c.getContext('2d');

  // sfondo
  const bg = ctx.createLinearGradient(0, 0, 0, H);
  bg.addColorStop(0, '#14313A'); bg.addColorStop(1, '#061116');
  ctx.fillStyle = bg; ctx.fillRect(0, 0, W, H);

  // titolo
  ctx.textAlign = 'center';
  ctx.fillStyle = '#E8B84E';
  ctx.font = '700 92px Fredoka, sans-serif';
  ctx.fillText('KARAOKE', W/2, 130);
  ctx.fillText('CON ALBERTO', W/2, 230);
  ctx.fillStyle = '#FF4757';
  ctx.font = '700 72px Fredoka, sans-serif';
  ctx.fillText('LA SFIDA!', W/2, 315);
  ctx.fillStyle = '#E8B84E';

  // riquadro bianco con QR
  const qrSize = 640;
  const qrX = (W - qrSize) / 2, qrY = 375;
  ctx.fillStyle = '#ffffff';
  const pad = 34;
  if(ctx.roundRect){
    ctx.beginPath();
    ctx.roundRect(qrX - pad, qrY - pad, qrSize + pad*2, qrSize + pad*2, 36);
    ctx.fill();
  } else {
    ctx.fillRect(qrX - pad, qrY - pad, qrSize + pad*2, qrSize + pad*2);
  }
  const qrSource = (qrCanvas || qrImg);
  if(qrSource) ctx.drawImage(qrSource, qrX, qrY, qrSize, qrSize);

  // istruzione + codice
  ctx.fillStyle = '#F5EEDC';
  ctx.font = '600 46px Fredoka, sans-serif';
  ctx.fillText('Inquadra ed entra in gara! 🎤', W/2, qrY + qrSize + 130);
  ctx.fillStyle = '#E8B84E';
  ctx.font = '700 96px "Space Mono", monospace';
  ctx.fillText(shareCode, W/2, qrY + qrSize + 270);

  document.body.removeChild(hidden);

  // 3) Condividi come file, con fallback al download
  c.toBlob(async (blob) => {
    if(!blob){ setStatus('Errore nella creazione dell\'immagine.'); return; }
    const file = new File([blob], 'karaoke-con-alberto-qr.png', { type: 'image/png' });
    if(navigator.canShare && navigator.canShare({ files: [file] })){
      try{
        await navigator.share({ files: [file], title: 'KARAOKE CON ALBERTO, LA SFIDA!', text: 'Inquadra il QR ed entra in gara! Codice: ' + shareCode });
        setStatus('');
        return;
      }catch(e){ /* condivisione annullata o non riuscita: si passa al download */ }
    }
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'karaoke-con-alberto-qr.png';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    setStatus('Immagine scaricata: la trovi nei Download, pronta da inviare.');
  }, 'image/png');
}

