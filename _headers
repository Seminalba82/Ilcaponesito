<body>
<div id="app"></div>
<script>
/* ---------- Storage: Firebase Realtime Database ----------
   kvdb.io e jsonblob.com si sono rivelati inaffidabili per l'uso diretto da
   browser (il primo richiede ora una vera verifica email; il secondo blocca
   le richieste multi-origine). Firebase Realtime Database di Google supporta
   nativamente le richieste dirette da pagine web via REST (basta aggiungere
   ".json" a qualsiasi indirizzo del database), proprio perché è pensato per
   essere usato così da app web e mobile. Richiede un database Firebase
   gratuito creato una tantum dal presentatore (account Google, "modalità di
   prova" = lettura/scrittura pubblica). Tutta la serata vive in un unico
   percorso JSON dentro quel database. */
let lastStorageError = null;

/* ---------- Configurazione fissa ----------
   L'indirizzo del database Firebase del presentatore è incorporato qui, una
   volta per tutte: così il codice della serata resta di soli 5 caratteri,
   dettabile a voce. Per usare un database diverso basta modificare questa
   riga (o usare il campo nelle impostazioni avanzate della creazione serata). */
const DEFAULT_DB_URL = 'https://karaoke-d0484-default-rtdb.europe-west1.firebasedatabase.app';

/* Indirizzo web pubblico dove è pubblicata questa app (Netlify): il QR di
   default diventa così un vero link cliccabile con il codice già incluso. */
const APP_PUBLIC_URL = location.origin + '/karaoke';

function normalizeDbUrl(url){
  return String(url || '').trim().replace(/\/+$/, '');
}

async function fbGet(dbUrl, path){
  try{
    const res = await fetch(`${dbUrl}/${path}.json`);
    if(!res.ok) throw new Error('HTTP ' + res.status);
    lastStorageError = null;
    const data = await res.json();
    return data; // null se il percorso non esiste ancora
  }catch(e){
    lastStorageError = (e && e.message) ? e.message : String(e);
    return null;
  }
}
async function fbSet(dbUrl, path, value){
  try{
    const res = await fetch(`${dbUrl}/${path}.json`, {
      method: 'PUT',
      body: JSON.stringify(value)
    });
    if(!res.ok) throw new Error('HTTP ' + res.status);
    lastStorageError = null;
    return true;
  }catch(e){
    lastStorageError = (e && e.message) ? e.message : String(e);
    return null;
  }
}
function sleep(ms){ return new Promise(res => setTimeout(res, ms)); }

/* Mostra a schermo intero una scritta neon lampeggiante per qualche secondo */
function showNeonOverlay(text, color, durationMs){
  const existing = document.getElementById('neonOverlay');
  if(existing) existing.remove();
  const el = document.createElement('div');
  el.id = 'neonOverlay';
  el.className = 'neon-overlay ' + (color === 'red' ? 'red' : 'gold');
  el.innerHTML = '<div class="neon-text">' + escapeHtml(text) + '</div>';
  el.onclick = () => el.remove();
  document.body.appendChild(el);
  setTimeout(() => { if(el.parentNode) el.remove(); }, durationMs || 4000);
}

/* Mostra una scritta neon gigante a tutto schermo per ~4 secondi. */
function showNeonOverlay(text, colorClass){
  const old = document.getElementById('neonOverlay');
  if(old) old.remove();
  const div = document.createElement('div');
  div.id = 'neonOverlay';
  div.className = 'neon-overlay';
  div.innerHTML = `<div class="neon-text ${colorClass}">${escapeHtml(text)}</div>`;
  document.body.appendChild(div);
  setTimeout(() => div.remove(), 4200);
}

function genCode(){
  const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  let out = '';
  for(let i=0;i<5;i++) out += chars[Math.floor(Math.random()*chars.length)];
  return out;
}

// Il codice condiviso con i partecipanti combina il codice breve della serata
// e l'indirizzo del database Firebase da usare, così basta un solo codice.
// Il codice breve (5 caratteri) usa il database incorporato nell'app.
// Per compatibilità, un codice lungo "ID|https://..." specifica il database.
function packCode(sessionId, dbUrl){
  return (dbUrl && dbUrl !== DEFAULT_DB_URL) ? (sessionId + '|' + dbUrl) : sessionId;
}
function unpackCode(code){
  const idx = code.indexOf('|');
  if(idx === -1) return { sessionId: code.toUpperCase(), dbUrl: DEFAULT_DB_URL };
  return { sessionId: code.slice(0, idx).toUpperCase(), dbUrl: code.slice(idx + 1) };
}

/* ---------- Helpers: misc ---------- */
function uid(){
  return (crypto && crypto.randomUUID) ? crypto.randomUUID() : 'p-' + Math.random().toString(36).slice(2) + Date.now();
}
function escapeHtml(s){
  return String(s || '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}
function sparkline(arr, w, h){
  w = w || 80; h = h || 26;
  if(!arr || !arr.length) return `<svg width="${w}" height="${h}"></svg>`;
  const max = Math.max(...arr, 0.02);
  const step = w / ((arr.length - 1) || 1);
  const pts = arr.map((v,i) => `${(i*step).toFixed(1)},${(h - (v/max)*h*0.9 - h*0.05).toFixed(1)}`).join(' ');
  return `<svg width="${w}" height="${h}" viewBox="0 0 ${w} ${h}"><polyline points="${pts}" fill="none" stroke="#E8B84E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
}
function computeScore(participantEnv, presenterEnv){
  if(!participantEnv || !presenterEnv || !participantEnv.length || !presenterEnv.length) return 0;
  const n = Math.min(participantEnv.length, presenterEnv.length, 10);
  const pArr = participantEnv.slice(-n);
  const rArr = presenterEnv.slice(-n);
  const norm = arr => { const m = Math.max(...arr, 0.02); return arr.map(v => v/m); };
  const pN = norm(pArr), rN = norm(rArr);
  let diffSum = 0;
  for(let i=0;i<n;i++) diffSum += Math.abs(pN[i]-rN[i]);
  const avgDiff = diffSum/n;
  return Math.round(Math.max(0, 1-avgDiff)*100);
}
function micErrorMessage(e){
  const insecure = (location.protocol !== 'https:' && location.hostname !== 'localhost');
  if(insecure){
    return "Il microfono è bloccato perché la pagina non è aperta da un indirizzo https:// (i browser lo permettono solo ai siti sicuri, non ai file aperti dai Download). Serve il link della serata pubblicato dal presentatore.";
  }
  const name = e && e.name;
  if(name === 'NotAllowedError' || name === 'PermissionDeniedError'){
    return "Permesso negato. Tocca l'icona del lucchetto vicino all'indirizzo, consenti il microfono per questo sito e riprova.";
  }
  if(name === 'NotFoundError' || name === 'DevicesNotFoundError'){
    return "Nessun microfono trovato su questo dispositivo.";
  }
  if(name === 'NotReadableError'){
    return "Il microfono risulta già in uso da un'altra app. Chiudila e riprova.";
  }
  return "Impossibile accedere al microfono (" + (e && e.message ? e.message : 'errore sconosciuto') + ").";
}

/* ---------- Mic engine ---------- */
class MicMeter{
  constructor(canvas, onLevel){
    this.canvas = canvas;
    this.ctx = canvas ? canvas.getContext('2d') : null;
    this.onLevel = onLevel || function(){};
    this.stream = null; this.audioCtx = null; this.analyser = null;
    this.freqData = null; this.timeData = null; this.rafId = null;
    this.currentRMS = 0; this.active = false;
  }
  async start(){
    // Modalità microfono standard: la modalità "grezza" (senza guadagno
    // automatico) satura il segnale su alcuni telefoni, quindi la evitiamo.
    // Il confronto delle onde è comunque normalizzato, perciò l'elaborazione
    // di sistema non falsa la classifica.
    this.stream = await navigator.mediaDevices.getUserMedia({ audio: true });
    this.audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    const source = this.audioCtx.createMediaStreamSource(this.stream);
    this.analyser = this.audioCtx.createAnalyser();
    this.analyser.fftSize = 256;
    source.connect(this.analyser);
    this.freqData = new Uint8Array(this.analyser.frequencyBinCount);
    this.timeData = new Uint8Array(this.analyser.fftSize);
    this.active = true;
    this._loop();
  }
  _loop(){
    if(!this.active) return;
    this.rafId = requestAnimationFrame(() => this._loop());
    this.analyser.getByteTimeDomainData(this.timeData);
    this.analyser.getByteFrequencyData(this.freqData);
    let sum = 0;
    for(let i=0;i<this.timeData.length;i++){ const v = (this.timeData[i]-128)/128; sum += v*v; }
    this.currentRMS = Math.sqrt(sum/this.timeData.length);
    this.onLevel(this.currentRMS);
    if(this.ctx) this._draw();
  }
  _draw(){
    const ctx = this.ctx, w = this.canvas.width, h = this.canvas.height;
    ctx.clearRect(0,0,w,h);
    const barCount = 32;
    const step = Math.max(1, Math.floor(this.freqData.length/barCount));
    const barW = (w/barCount) * 0.6;
    const gap = (w/barCount) * 0.4;
    ctx.fillStyle = '#E8B84E';
    for(let i=0;i<barCount;i++){
      let s = 0;
      for(let j=0;j<step;j++) s += this.freqData[i*step+j] || 0;
      const avg = (s/step)/255;
      const barH = Math.max(2, avg*h);
      const x = i*(barW+gap) + gap/2;
      ctx.fillRect(x, h-barH, barW, barH);
    }
  }
  stop(){
    this.active = false;
    if(this.rafId) cancelAnimationFrame(this.rafId);
    if(this.stream) this.stream.getTracks().forEach(t => t.stop());
    if(this.audioCtx && this.audioCtx.state !== 'closed') this.audioCtx.close();
  }
}

/* Immagine del microfono-mascotte, incorporata nel file (base64) */
const MIC_IMAGE_DATA = 'data:image/webp;base64,';

function micSVG(size){
  size = size || 160;
  return `
  <div class="mic-wrap mic-glow" id="micWrap" style="width:${size}px;height:${size}px;">
    <img src="${MIC_IMAGE_DATA}" alt="Microfono" style="width:100%;height:100%;object-fit:contain;display:block;">
  </div>`;
}

/* ---------- App state ---------- */
const App = {
  view: 'home', code: null, dbUrl: null, role: null, name: null, participantId: null,
  presenterName: 'Alberto', mic: null, envelope: [], timers: [],
  stageMode: false, muted: false,
  initCode: (new URLSearchParams(location.search)).get('code') || ''
};

function clearTimers(){ App.timers.forEach(id => clearInterval(id)); App.timers = []; }
function stopMic(){ if(App.mic){ App.mic.stop(); App.mic = null; } }
function cleanupView(){ clearTimers(); stopMic(); }
function goto(view){ cleanupView(); App.view = view; render(); }

/* Struttura dati ristrutturata per scalare:
   - karaoke_CODICE/board : il "tabellone" compatto, scritto SOLO dal presentatore
     (brano, stato gara, vincitori, classifica già calcolata, silenziati)
   - karaoke_CODICE/p/ID  : il nodo personale di ogni partecipante, scritto SOLO da lui
     (nome + ultime onde vocali)
   Così nessuno sovrascrive i dati degli altri e ogni telefono scambia pochi
   byte: il grosso (le onde di tutti) lo scarica solo il presentatore. */
function emptyBoard(name){
  return {
    songName: 'In attesa del primo brano…',
    presenterName: name,
