    <div class="screen">
      <div id="permGate" style="width:100%;">
        <h2 class="marquee-title display" style="font-size:24px;">ATTIVA IL MICROFONO</h2>
        <div class="card" style="display:flex;flex-direction:column;gap:14px;">
          <p class="subtitle" style="margin:0;">Per cantare, l'app deve accedere al microfono del tuo telefono. Le tue onde vocali saranno visibili al presentatore e agli altri partecipanti collegati con lo stesso codice.</p>
          <label style="display:flex;align-items:center;gap:10px;text-align:left;font-size:14px;cursor:pointer;">
            <input type="checkbox" id="consentCheck" style="width:20px;height:20px;flex-shrink:0;">
            Acconsento all'uso del microfono per questa serata
          </label>
          <button class="btn btn-primary" id="btnEnableMic" disabled>🎤 Attiva il mio microfono</button>
          <p class="hint" id="permError" style="color:var(--red);"></p>
        </div>
      </div>
      <div id="micUi" style="display:none;width:100%;">
        <div id="mutedBanner"></div>
        <div class="song-banner"><h2 class="marquee-title display" id="songTitle">🎵 —</h2></div>
        ${micSVG(190)}
        <canvas class="wave-canvas" id="waveCanvas" width="320" height="90"></canvas>
        <p class="hint" id="statusLine">—</p>
        <p class="rank-tag" id="rankTag"></p>
        <p class="subtitle">Stai cantando come <b>${escapeHtml(App.name)}</b></p>
      </div>
      <button class="btn btn-danger" style="max-width:420px;" id="btnExit">Esci dalla serata</button>
      <a class="follow-btn" href="https://linktr.ee/Albertoseminerio" target="_blank" rel="noopener">⭐ SEGUI ALBERTO</a>
    </div>`;

  document.getElementById('btnExit').onclick = () => { App.code=null; App.dbUrl=null; App.role=null; goto('home'); };

  const consentCheck = document.getElementById('consentCheck');
  const btnEnableMic = document.getElementById('btnEnableMic');
  consentCheck.onchange = () => { btnEnableMic.disabled = !consentCheck.checked; };

  btnEnableMic.onclick = async () => {
    const permError = document.getElementById('permError');
    permError.textContent = '';
    btnEnableMic.disabled = true;
    btnEnableMic.textContent = 'Richiesta permesso in corso…';
    try{
      const canvas = document.getElementById('waveCanvas');
      App.mic = new MicMeter(canvas, (rms) => {
        const w = document.getElementById('micWrap');
        if(w) w.style.setProperty('--lvl', rms.toFixed(3));
      });
      await App.mic.start();
      document.getElementById('permGate').style.display = 'none';
      document.getElementById('micUi').style.display = '';
      document.getElementById('statusLine').textContent = '🔴 Sei in diretta, canta pure!';
      startParticipantLoops();
    }catch(e){
      btnEnableMic.disabled = false;
      btnEnableMic.textContent = '🎤 Attiva il mio microfono';
      permError.textContent = micErrorMessage(e);
    }
  };

  function startParticipantLoops(){
    const path = 'karaoke_' + App.code;
    let localEnv = [];
    let prevContestActive = null; // null = primo giro, per non mostrare overlay all'ingresso
    const sampleTimer = setInterval(() => {
      if(App.mic){ localEnv.push(Number(App.mic.currentRMS.toFixed(3))); if(localEnv.length>40) localEnv.shift(); }
    }, 300);

    const syncTimer = setInterval(async () => {
      // Lettura: solo il tabellone compatto pubblicato dal presentatore
      const board = await fbGet(App.dbUrl, path + '/board');
      if(!board) return;

      // Annunci neon al cambio di stato della sfida
      const isActive = !!board.contestActive;
      if(prevContestActive !== null && isActive !== prevContestActive){
        if(isActive){
          showNeonOverlay('INIZIA LA SFIDA!', 'gold', 4500);
        } else {
          showNeonOverlay('SFIDA TERMINATA!', 'red', 4500);
        }
      }
      prevContestActive = isActive;

      const songTitle = document.getElementById('songTitle');
      if(songTitle) songTitle.textContent = '🎵 ' + (board.songName || '—');
      const mutedIds = board.mutedIds || [];
      App.muted = mutedIds.includes(App.participantId);
      const banner = document.getElementById('mutedBanner');
      if(banner){
        banner.innerHTML = App.muted ? '<div class="banner-muted">🔇 SEI STATO SILENZIATO DAL PRESENTATORE</div>' : '';
      }

      const standings = board.standings || [];
      const myIndex = standings.findIndex(p => p.id === App.participantId);
      const rankTag = document.getElementById('rankTag');
      const myWins = (board.wins || {})[App.participantId] || 0;
      const winsText = myWins ? ` — 🏆×${myWins}` : '';
      if(rankTag){
        if(board.contestActive){
          rankTag.textContent = (myIndex >= 0 ? `🏁 GARA IN CORSO! Sei #${myIndex+1} di ${standings.length}` : '🏁 GARA IN CORSO!') + winsText;
        } else if(board.lastWinner){
          rankTag.textContent = (board.lastWinner.id === App.participantId
            ? '🏆 HAI VINTO TU! Complimenti!'
            : `🏆 Ha vinto ${board.lastWinner.name}!`) + winsText;
        } else {
          rankTag.textContent = (myIndex >= 0 ? `Posizione in classifica: #${myIndex+1} di ${standings.length}` : '') + winsText;
        }
      }

      // Scrittura: solo il proprio nodo personale (pochi byte)
      if(App.mic && !App.muted){
        await fbSet(App.dbUrl, path + '/p/' + App.participantId, { name: App.name, envelope: localEnv.slice(-10), updatedAt: Date.now() });
      }
    }, 2000);

    App.timers.push(sampleTimer, syncTimer);
  }
}

/* ---------- Router ---------- */
const VIEWS = {
  home: renderHome,
  adminPin: renderAdminPin,
  adminCreate: renderAdminCreate,
  adminDashboard: renderAdminDashboard,
  participantJoin: renderParticipantJoin,
  participantMic: renderParticipantMic
};
function render(){ (VIEWS[App.view] || renderHome)(); }

// Se l'app è aperta da un link con codice (es. dal QR), si va direttamente
// alla schermata ospite con il codice già inserito, senza scelte intermedie.
if(App.initCode){ App.view = 'participantJoin'; }
render();

</script>
</body>
</html>
