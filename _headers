  html,body{margin:0;padding:0;height:100%;}
  body{
    background:
      repeating-linear-gradient(90deg, rgba(255,255,255,0.015) 0 2px, transparent 2px 26px),
      radial-gradient(ellipse at 50% -10%, var(--panel) 0%, var(--navy) 55%, var(--navy-deep) 100%);
