    text-shadow:0 0 8px var(--red),0 0 22px var(--red),0 0 48px var(--red),0 0 90px #ff0022; }
  @keyframes neonPulse{
    from{ opacity:1; transform:scale(1); }
    to{ opacity:0.55; transform:scale(1.06); }
  }
  @keyframes overlayFade{
    0%{ opacity:0; } 8%{ opacity:1; } 82%{ opacity:1; } 100%{ opacity:0; }
  }
