  .subtitle{color:var(--cream);opacity:0.75;font-size:14px;margin-top:-8px;}
  .song-banner{
    display:inline-block;
    background:linear-gradient(180deg, var(--panel-2), var(--navy-deep));
    border:2px solid var(--gold);
    border-radius:16px;
    padding:12px 22px;
