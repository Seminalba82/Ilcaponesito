/* Il PIN non è scritto in chiaro nel codice: viene salvata solo la sua
   "impronta" (hash SHA-256), confrontata con quella di ciò che si digita. */
const ADMIN_PIN_HASH = '6130bead2122e5ed59c9967e718b1a6c976f6c884d65fc63b7504427ff33dc75';

async function sha256Hex(text){
  const data = new TextEncoder().encode(text);
  const buf = await crypto.subtle.digest('SHA-256', data);
  return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
}

