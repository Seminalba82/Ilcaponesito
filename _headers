    --navy-deep:#061116;
    --panel:#14313A;
    --panel-2:#1C3D47;
    --gold:#E8B84E;
    --gold-dim:#B98F32;
    --cream:#F5EEDC;
    --red:#FF4757;
    --green:#5FB88B;
  }
