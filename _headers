  .display{font-family:'Fredoka',sans-serif; font-weight:700; letter-spacing:0.5px;}
  .mono{font-family:'Space Mono',monospace;}
  .screen{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:28px 18px;text-align:center;gap:18px;}
